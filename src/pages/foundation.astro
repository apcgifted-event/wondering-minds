---
import Base from '../layouts/Base.astro';
import TextPage from '../components/TextPage.astro';
import { getPage } from '../lib/sanity.ts';
import { foundationContent } from '../content/pages/foundation.ts';

const sanityDoc = await getPage('foundation', 'it');
const fallback = foundationContent.it;
const title = sanityDoc?.title ?? fallback.title;
---
<Base title={title}>
  <TextPage sanityDoc={sanityDoc} fallback={fallback} />
</Base>
