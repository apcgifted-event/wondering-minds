---
import Base from '../layouts/Base.astro';
---
<Base title="Partecipa al progetto">
  <section class="section">
    <div class="container" style="max-width: 70ch;">
      <span class="eyebrow">Wondering Minds</span>
      <h1 style="font-size: var(--step-2); color: var(--deep-forest); margin: 0.5rem 0 1rem;">Partecipa al progetto</h1>
      <p style="color: var(--ink-soft);">
        Contenuto in preparazione. Questa pagina e uno scaffold pronto da popolare
        tramite il CMS. Sostituisci questo testo con i contenuti definitivi.
      </p>
    </div>
  </section>
</Base>
