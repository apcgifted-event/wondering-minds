---
import Base from '../../../layouts/Base.astro';
import NewsPost from '../../../components/NewsPost.astro';
import { getNews, getNewsPost } from '../../../lib/sanity.ts';

export async function getStaticPaths() {
  const news = await getNews('en');
  const out = [];
  for (const n of news) {
    const post = await getNewsPost(n.slug, 'en');
    if (post) out.push({ params: { slug: n.slug }, props: { post } });
  }
  return out;
}
const { post } = Astro.props;
---
<Base title={post.title}>
  <NewsPost post={post} lang="en" />
</Base>
