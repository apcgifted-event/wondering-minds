---
import Base from '../../layouts/Base.astro';
import TextPage from '../../components/TextPage.astro';
import { getPage } from '../../lib/sanity.ts';
import { ambassadorContent } from '../../content/pages/ambassadors.ts';

const sanityDoc = await getPage('ambassadors', 'en');
const fallback = ambassadorContent.en;
const title = sanityDoc?.title ?? fallback.title;
---
<Base title={title}>
  <TextPage sanityDoc={sanityDoc} fallback={fallback} />
</Base>
