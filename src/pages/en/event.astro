---
import Base from '../../layouts/Base.astro';
import TextPage from '../../components/TextPage.astro';
import { getPage } from '../../lib/sanity.ts';
import { eventContent } from '../../content/pages/event.ts';

const sanityDoc = await getPage('event', 'en');
const fallback = eventContent.en;
const title = sanityDoc?.title ?? fallback.title;
---
<Base title={title}>
  <TextPage sanityDoc={sanityDoc} fallback={fallback} />
</Base>
