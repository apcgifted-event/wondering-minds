---
import Base from '../../layouts/Base.astro';
import TextPage from '../../components/TextPage.astro';
import { getPage } from '../../lib/sanity.ts';
import { contactContent } from '../../content/pages/misc.ts';

const sanityDoc = await getPage('contact', 'en');
const fallback = contactContent.en;
const title = sanityDoc?.title ?? fallback.title;
---
<Base title={title}>
  <TextPage sanityDoc={sanityDoc} fallback={fallback} />
</Base>
