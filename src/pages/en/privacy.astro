---
import Base from '../../layouts/Base.astro';
import TextPage from '../../components/TextPage.astro';
import { getPage } from '../../lib/sanity.ts';
import { privacyContent } from '../../content/pages/privacy.ts';

const sanityDoc = await getPage('privacy', 'en');
const fallback = privacyContent.en;
const title = sanityDoc?.title ?? fallback.title;
---
<Base title={title}>
  <TextPage sanityDoc={sanityDoc} fallback={fallback} />
</Base>
