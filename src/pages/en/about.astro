---
import Base from '../../layouts/Base.astro';
import TextPage from '../../components/TextPage.astro';
import { getPage } from '../../lib/sanity.ts';
import { aboutContent } from '../../content/pages/about.ts';

const sanityDoc = await getPage('about', 'en');
const fallback = aboutContent.en;
const title = sanityDoc?.title ?? fallback.title;
---
<Base title={title}>
  <TextPage sanityDoc={sanityDoc} fallback={fallback} />
</Base>
