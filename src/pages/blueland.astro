---
import Base from '../layouts/Base.astro';

const groups = [
  {
    age: '8–10 anni',
    title: 'Museo delle Invenzioni',
    slogan: 'Se lo immagini, puoi costruirlo.',
    body: 'I bambini entrano nel Museo delle Invenzioni di Blueland e creano un oggetto che aiuta le persone a stare meglio insieme: una macchina, uno zaino, un animale robot, una pianta speciale, uno strumento musicale.',
    output: 'Stand fisico del Museo, visitabile durante la fase “Visita a Blueland”.',
  },
  {
    age: '11–14 anni',
    title: 'La Scuola di Blueland',
    slogan: 'La scuola migliore del mondo esiste. Ve la raccontiamo noi.',
    body: 'Il gruppo progetta la scuola dove tutti adorano andare e la racconta attraverso un podcast: come sono fatte le aule, come si imparano le emozioni, come si valorizzano i talenti.',
    output: 'Podcast registrato (IT + EN), 6–8 minuti, riproducibile durante la visita.',
  },
  {
    age: '15–18 anni',
    title: 'Il Governo di Blueland',
    slogan: 'Una città così non nasce per caso. Siamo stati noi a costruirla.',
    body: 'I ragazzi sono il Consiglio dei Ministri di Blueland e raccontano come, in 70 anni, hanno trasformato la società: leggi, diritti, sanità mentale, progettazione dei social network.',
    output: 'Prodotto digitale (sito, TG del futuro, mini-documentario, manifesto) proiettabile durante la visita.',
  },
];
---
<Base title="Blueland 2100" description="Anno 2100: una città che ha imparato a prendersi cura di sé. I ragazzi ricostruiscono il segreto di Blueland.">
  <section class="bl-hero">
    <div class="container">
      <span class="eyebrow" style="color: var(--mint)">Laboratori · Bruxelles</span>
      <h1>Blueland 2100</h1>
      <p class="bl-lead">
        Anno 2100. Blueland è la città dove sono quasi scomparsi isolamento, solitudine,
        bullismo e ansia cronica. Non perché le persone siano perfette, ma perché la
        comunità ha imparato a prendersi cura di sé. I partecipanti sono chiamati a
        <strong> ricostruire il segreto di Blueland</strong>, divisi in tre gruppi per età.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container bl-groups">
      {groups.map((g, i) => (
        <article class="bl-group">
          <span class="bl-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <span class="bl-age">{g.age}</span>
          <h2>{g.title}</h2>
          <p class="bl-slogan">“{g.slogan}”</p>
          <p>{g.body}</p>
          <p class="bl-output"><strong>Prodotto finale:</strong> {g.output}</p>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .bl-hero { background: var(--forest-gradient); color: #fff; padding-block: clamp(3rem, 7vw, 5.5rem); }
  .bl-hero h1 { font-size: var(--step-3); margin: 0.4rem 0 1rem; }
  .bl-lead { max-width: 60ch; color: #dcebe0; font-size: var(--step-1); line-height: 1.5; }
  .bl-lead strong { color: var(--wonder-gold); }

  .bl-groups { display: grid; gap: 1.5rem; grid-template-columns: repeat(3, 1fr); }
  .bl-group { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); padding: 1.8rem; position: relative; }
  .bl-num { font-family: var(--font-display); font-size: 2.4rem; color: var(--mint); line-height: 1; }
  .bl-age { display: inline-block; margin: 0.4rem 0; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--growth-green); }
  .bl-group h2 { font-size: var(--step-1); color: var(--deep-forest); }
  .bl-slogan { font-family: var(--font-display); font-style: italic; color: var(--ink-soft); }
  .bl-output { font-size: 0.88rem; color: var(--ink-soft); border-top: 1px solid var(--line); padding-top: 0.8rem; margin-top: 1rem; }

  @media (max-width: 860px) { .bl-groups { grid-template-columns: 1fr; } }
</style>
