---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/ui.ts';

const { title, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const fullTitle = title ? `${title} — Wondering Minds` : 'Wondering Minds — European Gifted Minds';
const desc = description ?? 'Un\u2019iniziativa europea per ragazzi gifted e ad alto potenziale. Road to Brussels, 9 ottobre 2026.';

// hreflang per la coppia IT/EN della pagina corrente
const path = Astro.url.pathname.replace(/^\/en/, '') || '/';
const itHref = path === '/' ? '/' : path;
const enHref = `/en${path === '/' ? '/' : path}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="alternate" hreflang="it" href={itHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={itHref} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/images/logo.svg" type="image/svg+xml" />
    <!--
      NOTA COMPLIANCE: prima del go-live aggiungere qui il banner cookie
      GDPR-compliant (consenso esplicito, default privacy-first, nessun
      cookie di tracciamento prima del consenso). Validare con il Gruppo Legale.
      Nessuno script di analytics/social va caricato prima del consenso.
    -->
  </head>
  <body>
    <a class="skip-link" href="#main">Salta al contenuto</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
