---
// Pagina Gallery: griglia di immagini. Per ora segnaposto, dato che le foto
// non sono ancora disponibili. In futuro potrà leggere da una collezione Sanity.
import Placeholder from './Placeholder.astro';

const { lang } = Astro.props;
const t = {
  it: {
    eyebrow: 'Gallery',
    title: 'Momenti e storie',
    intro: 'Immagini, creativit\u00e0 e momenti dalla nostra comunit\u00e0. La galleria si popoler\u00e0 con l\u2019avvicinarsi e lo svolgersi dell\u2019evento.',
    empty: 'Le prime immagini arriveranno presto.',
  },
  en: {
    eyebrow: 'Gallery',
    title: 'Moments and stories',
    intro: 'Images, creativity and moments from our community. The gallery will fill up as the event approaches and unfolds.',
    empty: 'The first images are on their way.',
  },
}[lang];

// Segnaposto: 6 riquadri in attesa delle foto reali.
const slots = Array.from({ length: 6 });
---
<section class="gallery-hero">
  <div class="container">
    <span class="eyebrow" style="color: var(--mint)">{t.eyebrow}</span>
    <h1>{t.title}</h1>
    <p class="gallery-intro">{t.intro}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="gallery-grid">
      {slots.map((_, i) => (
        <Placeholder label={`Immagine ${i + 1}`} ratio="1 / 1" alt="" />
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-hero { background: var(--forest-gradient); color: #fff; padding-block: clamp(2.6rem, 6vw, 4.5rem); }
  .gallery-hero h1 { font-size: var(--step-3); margin: 0.4rem 0 0; }
  .gallery-intro { max-width: 56ch; color: #dcebe0; font-size: var(--step-1); line-height: 1.5; margin: 1rem 0 0; }

  .gallery-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }
</style>
