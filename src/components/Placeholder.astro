---
// Segnaposto immagine. Mostra un'area con etichetta finché non carichi la foto vera.
// Quando hai la foto: metti il file in public/images/ e passa 'src'.
const { label, ratio = '16 / 9', src, alt = '', rounded = false } = Astro.props;
---
{src ? (
  <img src={src} alt={alt} class:list={['ph-img', { 'ph-round': rounded }]} style={`aspect-ratio:${ratio}`} loading="lazy" />
) : (
  <div class:list={['ph', { 'ph-round': rounded }]} style={`aspect-ratio:${ratio}`} role="img" aria-label={alt || label}>
    <span class="ph-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6">
        <rect x="3" y="4" width="18" height="16" rx="2" />
        <circle cx="8.5" cy="9.5" r="1.5" />
        <path d="M21 16l-5-5L5 20" />
      </svg>
    </span>
    <span class="ph-label">{label}</span>
  </div>
)}

<style>
  .ph {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem;
    width: 100%; background: repeating-linear-gradient(135deg, #eef5ec, #eef5ec 12px, #e7f0e5 12px, #e7f0e5 24px);
    border: 1px dashed var(--leaf-green); border-radius: var(--radius); color: var(--growth-green);
    text-align: center; padding: 1rem;
  }
  .ph-icon { opacity: 0.7; }
  .ph-label { font-size: 0.8rem; font-weight: 600; max-width: 26ch; line-height: 1.3; }
  .ph-img { width: 100%; object-fit: cover; border-radius: var(--radius); display: block; }
  .ph-round, .ph-round.ph-img { border-radius: 999px; }
</style>
