---
// Pagina PDF: testo introduttivo (gestibile da Sanity, slug "pdf") + elenco
// documenti scaricabili (schema 'pdfDoc'). Mostra solo i documenti "online".
import { getPdfDocs, getPage } from '../lib/sanity.ts';

const { lang } = Astro.props;
const fb = {
  it: {
    eyebrow: 'Documenti',
    title: 'PDF',
    intro: 'Information for Participants, Associations, Schools, Universities and Organizations.',
    empty: 'I primi documenti saranno disponibili presto.',
    download: 'Scarica',
  },
  en: {
    eyebrow: 'Documents',
    title: 'PDF',
    intro: 'Information for Participants, Associations, Schools, Universities and Organizations.',
    empty: 'The first documents will be available soon.',
    download: 'Download',
  },
}[lang];

// Intestazione e testo gestibili da Sanity (pagina "Pagine di testo", slug "pdf").
const head = await getPage('pdf', lang);
const t = {
  eyebrow: head?.eyebrow ?? fb.eyebrow,
  title: head?.title ?? fb.title,
  intro: head?.intro ?? fb.intro,
};

const docs = await getPdfDocs(lang);

// Dimensione file leggibile (es. "1,2 MB").
function fmtSize(bytes) {
  if (!bytes) return '';
  const mb = bytes / (1024 * 1024);
  if (mb >= 1) return `${mb.toFixed(1).replace('.', lang === 'it' ? ',' : '.')} MB`;
  return `${Math.max(1, Math.round(bytes / 1024))} KB`;
}
---
<section class="pdf-hero">
  <div class="container">
    <span class="eyebrow" style="color: var(--mint)">{t.eyebrow}</span>
    <h1>{t.title}</h1>
    <p class="pdf-intro">{t.intro}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    {docs.length > 0 ? (
      <ul class="pdf-list">
        {docs.map((d) => (
          <li>
            <a class="pdf-item" href={d.url} target="_blank" rel="noopener noreferrer">
              <span class="pdf-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <path d="M14 2v6h6" />
                </svg>
              </span>
              <span class="pdf-info">
                <span class="pdf-title">{d.title}</span>
                {d.description && <span class="pdf-desc">{d.description}</span>}
                <span class="pdf-meta">PDF{d.size ? ` · ${fmtSize(d.size)}` : ''}</span>
              </span>
              <span class="pdf-cta">{fb.download} &darr;</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="pdf-empty">{fb.empty}</p>
    )}
  </div>
</section>

<style>
  .pdf-hero { background: var(--forest-gradient); color: #fff; padding-block: clamp(2.6rem, 6vw, 4.5rem); }
  .pdf-hero h1 { font-size: var(--step-3); margin: 0.4rem 0 0; }
  .pdf-intro { max-width: 60ch; color: #dcebe0; font-size: var(--step-1); line-height: 1.5; margin: 1rem 0 0; }

  .pdf-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.8rem; max-width: 820px; }
  .pdf-item {
    display: flex; align-items: center; gap: 1rem; text-decoration: none;
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius);
    padding: 1rem 1.2rem; transition: transform 0.15s ease, box-shadow 0.2s ease, border-color 0.15s;
  }
  .pdf-item:hover { transform: translateY(-2px); box-shadow: 0 14px 26px -18px rgba(26,92,56,0.5); border-color: var(--leaf-green); }
  .pdf-icon { flex-shrink: 0; width: 46px; height: 46px; display: grid; place-items: center; border-radius: 10px; background: #eef5ec; color: var(--growth-green); }
  .pdf-info { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 0; }
  .pdf-title { font-weight: 700; color: var(--deep-forest); }
  .pdf-desc { font-size: 0.88rem; color: var(--ink-soft); }
  .pdf-meta { font-size: 0.75rem; color: var(--ink-soft); letter-spacing: 0.04em; text-transform: uppercase; }
  .pdf-cta { flex-shrink: 0; font-weight: 700; font-size: 0.85rem; color: var(--growth-green); white-space: nowrap; }

  .pdf-empty { padding: 2.5rem; text-align: center; color: var(--ink-soft); border: 1px dashed var(--mint); border-radius: var(--radius); background: #fff; }

  @media (max-width: 560px) {
    .pdf-item { flex-wrap: wrap; }
    .pdf-cta { width: 100%; text-align: right; }
  }
</style>
