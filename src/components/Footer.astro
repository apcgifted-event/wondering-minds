---
import { useTranslations, getLangFromUrl } from '../i18n/ui.ts';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = lang === 'en' ? '/en' : '';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-name"><strong>W</strong>ondering <strong>M</strong>inds</span>
      <p class="foundation-note">{t('foundation.note')}</p>
    </div>

    <blockquote class="footer-quote">
      <span class="star" aria-hidden="true">&#9733;</span>
      <p>&ldquo;{t('footer.quote')}&rdquo;</p>
    </blockquote>

    <div class="footer-social">
      <span class="eyebrow">{t('footer.follow')}</span>
      <ul>
        <li><a href="#" aria-label="Instagram">Instagram</a></li>
        <li><a href="#" aria-label="Facebook">Facebook</a></li>
        <li><a href="#" aria-label="YouTube">YouTube</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-legal">
    <p>
      &copy; {year} Carano 4 Children &mdash; Fondation priv&eacute;e &middot;
      Rue Belliard 202, 1040 Brussels, Belgium &middot;
      <a href="mailto:info@carano4children.org">info@carano4children.org</a>
    </p>
    <p class="footer-links">
      <a href={`${base}/privacy`}>{t('footer.privacy')}</a>
      <span aria-hidden="true">&middot;</span>
      <a href={`${base}/privacy#titolare`}>{t('footer.legal')}</a>
    </p>
  </div>
</footer>

<style>
  .site-footer { background: var(--forest-gradient); color: #eaf3ec; margin-top: 4rem; }
  .footer-inner {
    display: grid; grid-template-columns: 1fr 1.4fr 1fr; gap: 2rem; align-items: center;
    padding-block: 2.6rem;
  }
  .brand-name { font-family: var(--font-display); font-size: 1.4rem; color: #fff; }
  .brand-name strong { color: var(--wonder-gold); }
  .foundation-note { font-size: 0.85rem; color: #bcd4c3; margin: 0.4rem 0 0; }

  .footer-quote { text-align: center; margin: 0; }
  .footer-quote p { font-family: var(--font-display); font-style: italic; font-size: var(--step-1); color: #fff; margin: 0.3rem 0 0; }

  .footer-social { text-align: right; }
  .footer-social .eyebrow { color: var(--mint); }
  .footer-social ul { list-style: none; margin: 0.5rem 0 0; padding: 0; display: flex; gap: 1rem; justify-content: flex-end; }
  .footer-social a { color: #eaf3ec; text-decoration: none; font-size: 0.9rem; }
  .footer-social a:hover { color: var(--wonder-gold); }

  .footer-legal {
    border-top: 1px solid rgba(255,255,255,0.15); padding-block: 1.2rem;
    display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    font-size: 0.8rem; color: #bcd4c3;
  }
  .footer-legal a { color: #d7e7db; }
  .footer-links { display: flex; gap: 0.6rem; }

  @media (max-width: 760px) {
    .footer-inner { grid-template-columns: 1fr; text-align: center; }
    .footer-social { text-align: center; }
    .footer-social ul { justify-content: center; }
    .footer-legal { justify-content: center; text-align: center; }
  }
</style>
