---
// Pagina News & aggiornamenti: elenco che legge da Sanity (schema 'newsPost').
// Ogni voce rimanda alla pagina di dettaglio /news/<slug>.
import { getNews } from '../lib/sanity.ts';
import Placeholder from './Placeholder.astro';

const { lang } = Astro.props;
const t = {
  it: {
    eyebrow: 'News',
    title: 'News e aggiornamenti',
    intro: 'Segui il percorso del progetto: novità, tappe e storie da Road to Brussels.',
    empty: 'I primi aggiornamenti arriveranno presto.',
    read: 'Leggi',
    locale: 'it-IT',
  },
  en: {
    eyebrow: 'News',
    title: 'News & updates',
    intro: 'Follow the project journey: news, milestones and stories from Road to Brussels.',
    empty: 'The first updates are on their way.',
    read: 'Read',
    locale: 'en-GB',
  },
}[lang];
const base = lang === 'en' ? '/en' : '';

const news = await getNews(lang);
function fmtDate(d) {
  if (!d) return '';
  try { return new Date(d).toLocaleDateString(t.locale, { day: 'numeric', month: 'long', year: 'numeric' }); }
  catch { return d; }
}
---
<section class="news-hero">
  <div class="container">
    <span class="eyebrow" style="color: var(--mint)">{t.eyebrow}</span>
    <h1>{t.title}</h1>
    <p class="news-intro">{t.intro}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    {news.length > 0 ? (
      <div class="news-grid">
        {news.map((n) => (
          <a class="news-card" href={`${base}/news/${n.slug}`}>
            <div class="news-cover">
              {n.coverUrl ? (
                <img src={n.coverUrl} alt={n.title} loading="lazy" />
              ) : (
                <Placeholder label="" ratio="16 / 9" alt="" />
              )}
            </div>
            <div class="news-body">
              <time class="news-date">{fmtDate(n.date)}</time>
              <h2 class="news-title">{n.title}</h2>
              <p class="news-summary">{n.summary}</p>
              <span class="news-read">{t.read} &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="news-empty">{t.empty}</p>
    )}
  </div>
</section>

<style>
  .news-hero { background: var(--forest-gradient); color: #fff; padding-block: clamp(2.6rem, 6vw, 4.5rem); }
  .news-hero h1 { font-size: var(--step-3); margin: 0.4rem 0 0; }
  .news-intro { max-width: 56ch; color: #dcebe0; font-size: var(--step-1); line-height: 1.5; margin: 1rem 0 0; }

  .news-grid { display: grid; gap: 1.4rem; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
  .news-card { display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; text-decoration: none; background: #fff; transition: transform 0.15s, box-shadow 0.2s; }
  .news-card:hover { transform: translateY(-3px); box-shadow: 0 16px 30px -20px rgba(26,92,56,0.5); }
  .news-cover { aspect-ratio: 16 / 9; background: #eef5ec; }
  .news-cover img { width: 100%; height: 100%; object-fit: cover; }
  .news-body { padding: 1.1rem 1.3rem 1.4rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .news-date { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--growth-green); }
  .news-title { font-size: var(--step-1); color: var(--deep-forest); line-height: 1.2; }
  .news-summary { font-size: 0.9rem; color: var(--ink-soft); margin: 0; flex: 1; }
  .news-read { font-weight: 700; font-size: 0.85rem; color: var(--growth-green); margin-top: 0.3rem; }

  .news-empty { padding: 2.5rem; text-align: center; color: var(--ink-soft); border: 1px dashed var(--mint); border-radius: var(--radius); background: #fff; }
</style>
